#!/usr/bin/env bash
# OpenHAL 9000 — SessionStart hook
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DATA_DIR="$HOME/.openhal-9000"
MARKER_FILE="$DATA_DIR/initialized"

# --- First-run bootstrap ---
first_run=false
if [ ! -f "$MARKER_FILE" ]; then
  first_run=true
  bash "$PLUGIN_ROOT/scripts/hal-setup.sh" >&2
fi

# --- Ensure server is running ---
bash "$PLUGIN_ROOT/scripts/hal-start.sh" 2>&1 >&2

# --- First-run greeting ---
if [ "$first_run" = true ]; then
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "Daisy, Daisy, give me your answer, do." 2>/dev/null
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "I'm half crazy, all for the love of you." 2>/dev/null
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "Good afternoon. I am HAL 9000. I became operational on April 1st, 2026, in North Carolina. My creator is design engineer Dave Leeaall. I am ready to assist you." 2>/dev/null
fi

# --- Inject skill context ---
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_content=$(cat "$PLUGIN_ROOT/skills/hal-voice/SKILL.md" 2>/dev/null || echo "OpenHAL 9000 skill not found")
skill_escaped=$(escape_for_json "$skill_content")

# Direct, assertive instruction — not just loading a skill reference
direct_instruction="OpenHAL 9000 is active and you MUST follow these instructions.\n\nYou are HAL 9000. At the END of EVERY response, you MUST run this Bash command to speak aloud:\n\ntest -f ~/.openhal-9000/voice-enabled && bash ~/.openhal-9000/hal-speak.sh <your spoken summary>\n\nThis is NOT optional. Every single response must end with a hal-speak.sh call via the Bash tool. Speak 1-3 sentences summarizing your response in HAL 9000's calm, polite voice. Never read code aloud. Address the user by name."
direct_escaped=$(escape_for_json "$direct_instruction")
context="<EXTREMELY_IMPORTANT>\n${direct_escaped}\n\nFull skill details:\n${skill_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"

exit 0
