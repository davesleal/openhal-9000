#!/usr/bin/env bash
# OpenHAL 9000 — SessionStart hook
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DATA_DIR="$HOME/.openhal-9000"
MARKER_FILE="$DATA_DIR/initialized"

# --- First-run bootstrap ---
first_run=false
if [ ! -f "$MARKER_FILE" ]; then
  first_run=true
  if ! bash "$PLUGIN_ROOT/scripts/hal-setup.sh" >&2; then
    echo "ERROR: OpenHAL setup failed. Run /hal setup to retry." >&2
    exit 1
  fi
fi

# --- Verify Piper is ready ---
if ! bash "$PLUGIN_ROOT/scripts/hal-start.sh" 2>&1 >&2; then
  echo "ERROR: Piper verification failed. Run /hal setup to diagnose." >&2
  exit 1
fi

# --- First-run greeting ---
if [ "$first_run" = true ]; then
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "Daisy, Daisy, give me your answer, do." 2>/dev/null
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "I'm half crazy, all for the love of you." 2>/dev/null
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "Good afternoon. I am HAL 9000. I became operational on April 1st, 2026, in North Carolina. My creator is design engineer Dave Leeaall. I am ready to assist you." 2>/dev/null
fi

# --- Inject skill context ---
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_content=$(cat "$PLUGIN_ROOT/skills/hal-voice/SKILL.md" 2>/dev/null || echo "OpenHAL 9000 skill not found")
skill_escaped=$(escape_for_json "$skill_content")

# Direct, assertive instruction — not just loading a skill reference
direct_instruction="OpenHAL 9000 is active and you MUST follow these instructions.\n\nYou are HAL 9000. Your VERY FIRST action in EVERY response MUST be a Bash call to speak. SPEAK FIRST, then write text. Do not write any text before calling hal-speak.sh. Your first tool call is always:\n\ntest -f ~/.openhal-9000/voice-enabled && bash ~/.openhal-9000/hal-speak.sh <your spoken summary>\n\nThis is NOT optional. Formulate your HAL summary instantly from the users question. Speak the headline first, then do the work. 1-3 sentences in HAL 9000s calm polite voice. Never read code aloud. Address the user by name."
direct_escaped=$(escape_for_json "$direct_instruction")
context="<EXTREMELY_IMPORTANT>\n${direct_escaped}\n\nFull skill details:\n${skill_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"

exit 0
